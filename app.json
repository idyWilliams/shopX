{
  "expo": {
    "name": "shopX",
    "slug": "shopx",
    "version": "1.0.0",
    "scheme": "shopx",
    "platforms": ["ios", "android", "web"],
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      "expo-router"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shopx.app"
    },
    "android": {
      "package": "com.shopx.app"
    }
  }
}
